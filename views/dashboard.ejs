<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard - TechSphere Academy</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
</head>
<body>
    <%- include('partials/header') %>

    <main class="container py-5">
        <div class="row">
            <!-- Profile Column -->
            <div class="col-lg-4 mb-4">
                <div class="card shadow-sm h-100">
                    <div class="card-body text-center">
                        <% if (student.profileImage) { %>
                            <img src="<%= student.profileImage %>" alt="Profile Image" class="rounded-circle mb-3" width="150" height="150" style="object-fit: cover;">
                        <% } else { %>
                            <div class="rounded-circle bg-light d-flex align-items-center justify-content-center mb-3" style="width: 150px; height: 150px; margin: 0 auto;">
                                <i class="bi bi-person" style="font-size: 3rem; color: var(--neutral-3);"></i>
                            </div>
                        <% } %>
                        <h4 class="mb-2"><%= student.name %></h4>
                        <p class="text-muted mb-3">
                            <i class="bi bi-person-badge"></i> <%= student.regNumber %>
                        </p>
                        <div class="d-grid gap-2">
                            <a href="/change-password" class="btn btn-outline-primary">
                                <i class="bi bi-key"></i> Change Password
                            </a>
                            <a href="/profile/edit" class="btn btn-outline-secondary">
                                <i class="bi bi-pencil"></i> Edit Profile
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Main Content Column -->
            <div class="col-lg-8">
                <!-- Welcome Alert -->
                <% if (success) { %>
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        <%= success %>
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                <% } %>

                <!-- Dashboard Cards -->
                <div class="row mb-4">
                    <div class="col-md-6 mb-3">
                        <div class="card bg-primary text-white h-100">
                            <div class="card-body">
                                <h5 class="card-title">
                                    <i class="bi bi-journal-bookmark"></i> My Course
                                </h5>
                                <p class="card-text display-6"><%= student.course %></p>
                                <a href="/courses" class="btn btn-light btn-sm">View Details</a>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6 mb-3">
                        <div class="card bg-success text-white h-100">
                            <div class="card-body">
                                <h5 class="card-title">
                                    <i class="bi bi-award"></i> Registration Status
                                </h5>
                                <p class="card-text display-6">Active</p>
                                <small>Since: <%= student.createdAt.toLocaleDateString() %></small>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Progress Section -->
                <div class="card mb-4">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0">
                            <i class="bi bi-graph-up"></i> Course Progress
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <div class="d-flex justify-content-between mb-1">
                                <span>Completion Status</span>
                                <span>65% Complete</span>
                            </div>
                            <div class="progress" style="height: 10px;">
                                <div class="progress-bar bg-success" role="progressbar" style="width: 65%;" aria-valuenow="65" aria-valuemin="0" aria-valuemax="100"></div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-4 mb-2">
                                <div class="card bg-light h-100">
                                    <div class="card-body text-center">
                                        <h6 class="card-title">Completed Modules</h6>
                                        <p class="display-5 text-success">5</p>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-4 mb-2">
                                <div class="card bg-light h-100">
                                    <div class="card-body text-center">
                                        <h6 class="card-title">Current Module</h6>
                                        <p class="display-5 text-primary">3</p>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-4 mb-2">
                                <div class="card bg-light h-100">
                                    <div class="card-body text-center">
                                        <h6 class="card-title">Remaining</h6>
                                        <p class="display-5 text-warning">3</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Quick Actions -->
                <div class="card mb-4">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0">
                            <i class="bi bi-lightning"></i> Quick Actions
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="row g-2">
                            <div class="col-md-4">
                                <a href="/courses" class="btn btn-outline-primary w-100">
                                    <i class="bi bi-collection-play"></i> My Courses
                                </a>
                            </div>
                            <div class="col-md-4">
                                <a href="/assignments" class="btn btn-outline-primary w-100">
                                    <i class="bi bi-journal-text"></i> Assignments
                                </a>
                            </div>
                            <div class="col-md-4">
                                <a href="/resources" class="btn btn-outline-primary w-100">
                                    <i class="bi bi-folder"></i> Resources
                                </a>
                            </div>
                            <div class="col-md-4">
                                <a href="/grades" class="btn btn-outline-primary w-100">
                                    <i class="bi bi-award"></i> Grades
                                </a>
                            </div>
                            <div class="col-md-4">
                                <a href="/messages" class="btn btn-outline-primary w-100">
                                    <i class="bi bi-chat-left-text"></i> Messages
                                </a>
                            </div>
                            <div class="col-md-4">
                                <a href="/settings" class="btn btn-outline-primary w-100">
                                    <i class="bi bi-gear"></i> Settings
                                </a>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Personal Information -->
                <div class="card">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0">
                            <i class="bi bi-person-lines-fill"></i> Personal Information
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <h6><i class="bi bi-envelope"></i> Email</h6>
                                <p><%= student.email %></p>
                            </div>
                            <div class="col-md-6 mb-3">
                                <h6><i class="bi bi-telephone"></i> Phone</h6>
                                <p><%= student.phone %></p>
                            </div>
                            <div class="col-12 mb-3">
                                <h6><i class="bi bi-geo-alt"></i> Address</h6>
                                <p><%= student.address %></p>
                            </div>
                            <div class="col-md-6 mb-3">
                                <h6><i class="bi bi-person-circle"></i> Username</h6>
                                <p><%= student.username %></p>
                            </div>
                            <div class="col-md-6 mb-3">
                                <h6><i class="bi bi-card-checklist"></i> Registration Number</h6>
                                <p><%= student.regNumber %></p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <%- include('partials/footer') %>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Activate tooltips
        const tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
        tooltipTriggerList.map(function (tooltipTriggerEl) {
            return new bootstrap.Tooltip(tooltipTriggerEl);
        });
    </script>
</body>
</html>